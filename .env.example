# ============================================================
# APEX ALPHA BOT — CONFIG. Copy this file to ".env" and edit.
# NEVER commit or share your real .env — it holds your keys.
# ============================================================

# ---- MODE ----
# paper  = simulated money, real market prices, NO keys needed (START HERE)
# live   = real orders with real money (only after paper proves an edge)
MODE=paper

# ---- EXCHANGE (crypto) ----
EXCHANGE=kraken
SYMBOL=BTC/USD
TIMEFRAME=15m

# API keys ONLY needed for MODE=live. Leave blank for paper.
API_KEY=
API_SECRET=

# ---- ACCOUNT / RISK ----
START_EQUITY=100          # paper starting balance (live reads real balance)
RISK_PCT=0.02             # fraction of equity risked per trade (0.02 = 2%)
MAX_DAILY_LOSS_PCT=0.04   # halt trading for the day at this drawdown
RR=2.0                    # take-profit reward:risk multiple (>=2 enforced)
ATR_MULT=1.5              # stop distance = ATR * this
MAX_LEVERAGE=1.0          # 1.0 = spot, no leverage (recommended)

# ---- STRATEGY (EMA crossover + ATR) ----
EMA_FAST=9
EMA_SLOW=21
ATR_PERIOD=14
POLL_SECONDS=60           # how often the loop checks the market

# ---- NOTIFICATIONS (optional; leave blank to disable) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ---- TRADINGVIEW / TRADEVISOR WEBHOOK ----
WEBHOOK_SECRET=change-me          # shared secret; must match your TradingView alert JSON
WEBHOOK_PORT=8080                 # internal port; Caddy proxies 443 -> this
WEBHOOK_STOP_PCT=0.01

# ---- CLOUD DEPLOY (only used by docker-compose + Caddy auto-HTTPS) ----
APEX_DOMAIN=yourname.duckdns.org  # your free DuckDNS subdomain, pointed at the VM's public IP
LETSENCRYPT_EMAIL=you@example.com # for the free TLS certificate (renewal notices only)
